@using filipealmeida.Models
@inject IJSRuntime JS
@inject DataService DataService

<nav class="navbar navbar-expand-lg navbar-dark fixed-top px-4">
    <div class="container">
        <a class="navbar-brand" href="#">
            <span>Filipe Almeida</span>
            @if (DataService.Bio != null)
            {
                <span class="separator">|</span>
                <span class="left-span">@DataService.Bio.Title</span>
            }
        </a>
        @if (DataService.Bio != null) {
            <div class="socials">
                <a href="@DataService.Bio.LinkedIn" target="_blank" aria-label="LinkedIn profile of Filipe Almeida" role="link">
                    <i class="fa-brands fa-linkedin"></i>
                </a>
            </div>
        }
    </div>
</nav>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("navbarScroll.init");
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await DataService.EnsureLoadedAsync();
    }
}