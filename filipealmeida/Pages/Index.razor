@page "/"
@using System.Globalization
@using filipealmeida.Models
@inject DataService DataService
@inject IJSRuntime JSRuntime

<div id="home" class="hero-section animate__animated animate__fadeInUp" role="region" aria-label="Hero Section">
    @if (DataService.Bio != null)
    {
        <div class="hero-container container text-center">
            <div class="portrait-container">
                <img src="images/portrait.jpg" alt="Portrait" class="portrait-image" />
            </div>
            <div class="text-container">
                <h1 class="display-4">@DataService.Bio.Name</h1>
                <p class="summary-text lead">@DataService.Bio.Summary</p>
            </div>
        </div>
    }
</div>

<div id="skills" class="" role="region" aria-label="Skills Section">
    <div class="container">
        @if (DataService.Skills != null)
        {
            <p style="text-align: center;">
                @foreach (var skill in DataService.Skills.OrderByDescending(s => int.Parse(s.Proficiency)))
                {
                    <span class="skill-pill">@skill.Name</span>
                }
            </p>
        }
    </div>
</div>

<div id="experience" role="region" aria-label="Experience Section">
    <div class="container">

        @if (DataService.Experiences != null)
        {
            <div class="timeline">
                @foreach (var experience in DataService.Experiences.OrderByDescending(e => e.From))
                {
                    <div class="timeline-item" role="article" aria-label="@experience.Title at @experience.Company">
                        <div class="timeline-content">
                        <div class="mb-3">
                            <h4 class="card-title">@experience.Title</h4>
                            <h5 class="card-title">@experience.From.ToString("MMM yyyy", cultureInfo) - 
                            @(experience.To == null ? "current" : experience.To.Value.ToString("MMM yyyy", cultureInfo))</h5>
                        </div>
                            <p class="card-text">@experience.Company<br>@experience.Location</p>
                            <p class="card-text description"> @experience.Description</p>
                        </div>
                    </div>
                }
                <div class="scroll-to-top-wrapper" @onclick="ScrollToTop">
                    <a id="scroll-to-top" class="scroll-to-top-button">
                    </a>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private CultureInfo? cultureInfo;
    private bool hasInitializedTimeline = false;

    protected override async Task OnInitializedAsync()
    {
        cultureInfo = new CultureInfo("en-US");
        await DataService.EnsureLoadedAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (DataService.Experiences != null && !hasInitializedTimeline)
        {
            hasInitializedTimeline = true;
            await JSRuntime.InvokeVoidAsync("initTimeline");
        }
    }

    private async Task ScrollToTop()
    {
        await JSRuntime.InvokeVoidAsync("window.navbarScroll.scrollToTop");
    }
}